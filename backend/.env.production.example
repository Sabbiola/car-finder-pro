ENV=production
LOG_LEVEL=info
FASTAPI_ROOT_PATH=
CORS_ORIGINS=https://carfinderpro.app
REQUEST_TIMEOUT_SECONDS=20
MAX_PROVIDER_CONCURRENCY=8
PROVIDER_TIMEOUT_SECONDS=25
PROVIDER_RETRY_ATTEMPTS=2
PROVIDER_RETRY_BACKOFF_MS=200
ANALYSIS_MAX_CONCURRENCY=12
DISABLED_PROVIDERS=
SCRAPINGBEE_API_KEY=
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_IT
# Provider secrets for real runtime (TEST_STUB_MODE=false):
# - autoscout24, subito, automobile, brumbrum -> SCRAPINGBEE_API_KEY
# - ebay -> EBAY_CLIENT_ID + EBAY_CLIENT_SECRET
OBSERVABILITY_WEBHOOK_URL=
OBSERVABILITY_WEBHOOK_TIMEOUT_SECONDS=2
ALERTS_PROCESSOR_TOKEN=
ALERTS_RETRY_MAX_ATTEMPTS=3
ALERTS_RETRY_BASE_SECONDS=300
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_BASE_URL=https://api.resend.com
LEGACY_SCRAPE_LISTINGS_URL=
FASTAPI_PROXY_MODE=fastapi_only
OPS_TOKEN=
TEST_STUB_MODE=false
# Keep false in production.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
ANALYSIS_SNAPSHOT_TTL_HOURS=24
NEGOTIATION_LLM_ENABLED=false
