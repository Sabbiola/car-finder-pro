ENV=development
LOG_LEVEL=info
FASTAPI_ROOT_PATH=
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
REQUEST_TIMEOUT_SECONDS=20
MAX_PROVIDER_CONCURRENCY=4
PROVIDER_TIMEOUT_SECONDS=30
PROVIDER_RETRY_ATTEMPTS=3
PROVIDER_RETRY_BACKOFF_MS=250
ANALYSIS_MAX_CONCURRENCY=8
DISABLED_PROVIDERS=
SCRAPINGBEE_API_KEY=
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_IT
# Provider secrets for real smoke (TEST_STUB_MODE=false):
# - autoscout24, subito, automobile, brumbrum -> SCRAPINGBEE_API_KEY
# - ebay -> EBAY_CLIENT_ID + EBAY_CLIENT_SECRET
OBSERVABILITY_WEBHOOK_URL=
OBSERVABILITY_WEBHOOK_TIMEOUT_SECONDS=2
ALERTS_PROCESSOR_TOKEN=
ALERTS_RETRY_MAX_ATTEMPTS=3
ALERTS_RETRY_BASE_SECONDS=300
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_BASE_URL=https://api.resend.com
LEGACY_SCRAPE_LISTINGS_URL=
FASTAPI_PROXY_MODE=primary_with_fallback
OPS_TOKEN=
TEST_STUB_MODE=false
# Set TEST_STUB_MODE=true only for contract smoke without external providers.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
ANALYSIS_SNAPSHOT_TTL_HOURS=24
NEGOTIATION_LLM_ENABLED=false
